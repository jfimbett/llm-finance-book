{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://llm-finance-book/docs/quality/score-schema.json",
  "title": "Book-Quality Chapter Scorecard",
  "description": "0-100, 14-dimension scorecard for one chapter. Pass iff every applicable dimension >= 90. A dimension may be null (N/A, e.g. no code/figures) which does not block pass.",
  "type": "object",
  "required": ["file", "reading_index", "slug", "date", "scope", "dimensions", "pass", "threshold"],
  "properties": {
    "file": { "type": "string", "description": "Path to the audited chapter.tex" },
    "reading_index": { "type": "integer", "minimum": 1, "description": "Position in main.tex \\include order (NOT folder number)" },
    "slug": { "type": "string", "description": "Chapter folder slug, e.g. 05-business-valuation" },
    "title": { "type": "string" },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "scope": { "type": "string", "enum": ["chapter", "book"] },
    "threshold": { "type": "integer", "const": 90 },
    "dimensions": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "object",
        "required": ["dimension", "score", "pass", "evidence", "blocking_issues", "recommended_action"],
        "properties": {
          "dimension": {
            "type": "string",
            "enum": [
              "correctness",
              "concept_separation",
              "code_figure_correctness",
              "concept_ordering",
              "progressive_learning",
              "non_repetition",
              "finance_orientation",
              "finance_examples",
              "citation_hygiene",
              "citation_accuracy",
              "completeness",
              "notation_crossref",
              "reproducibility",
              "pedagogy"
            ]
          },
          "score": {
            "type": ["integer", "null"],
            "minimum": 0,
            "maximum": 100,
            "description": "0-100, or null when the dimension does not apply to this chapter"
          },
          "pass": { "type": "boolean", "description": "true iff score >= 90 OR score is null (N/A)" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Concrete citations: 'file:line — observation'"
          },
          "blocking_issues": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Issues (with severity tag) preventing a >=90 score"
          },
          "recommended_action": {
            "type": "string",
            "description": "Smallest change likely to raise the dimension to >=90, or NEEDS_EXTERNAL_VERIFICATION / NONE"
          }
        }
      }
    },
    "pass": { "type": "boolean", "description": "true iff every dimension with non-null score is >= 90" },
    "iteration": { "type": "integer", "minimum": 0, "description": "Editing-loop iteration that produced this scorecard (0 = initial audit)" },
    "notes": { "type": "string" }
  }
}
